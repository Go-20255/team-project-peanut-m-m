meta {
  name: roll dice
  type: http
  seq: 11
}

post {
  url: http://localhost:9876/api/game/roll
  body: formUrlEncoded
  auth: inherit
}

body:form-urlencoded {
  session_id: {{session_id}}
  player_id: {{id}}
}

vars:pre-request {
  id: 1
  session_id: 2ab36b1a-f2fc-4543-a146-6b4bc31d55bd
}

settings {
  encodeUrl: true
  timeout: 0
}
