meta {
  name: connect to live game
  type: http
  seq: 5
}

get {
  url: http://localhost:9876/api/game/join/live?session_id={{session_id}}
  body: formUrlEncoded
  auth: inherit
}

params:query {
  session_id: {{session_id}}
}

body:form-urlencoded {
  player_id: 4
  player_name: banana_man
}

vars:pre-request {
  session_id: 5b193900-2e2d-4e53-a8b2-92174cade426
}

settings {
  encodeUrl: true
  timeout: 0
}
