meta {
  name: connect to live game
  type: http
  seq: 5
}

get {
  url: http://localhost:9876/api/game/join/live?session_id={{session_id}}&player_id=1&player_name=banana_man
  body: none
  auth: inherit
}

params:query {
  session_id: {{session_id}}
  player_id: 1
  player_name: banana_man
}

vars:pre-request {
  session_id: 92b80c79-c1f4-4dd5-9ce9-583be7599382
}

settings {
  encodeUrl: true
  timeout: 0
}
